# Public store domain (no https). Create a Storefront API app in Shopify Admin → Settings → Apps → Develop apps.
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API access token from the same app (NOT the Admin API token — shpat_… will get 401 here).
# For customer sign-in, enable Storefront API scopes: unauthenticated_read_customers, unauthenticated_write_customers
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token

# Optional. Defaults to 2024-10. Use a version your app supports: https://shopify.dev/docs/api/usage/versioning
# NEXT_PUBLIC_SHOPIFY_STOREFRONT_API_VERSION=2024-10
